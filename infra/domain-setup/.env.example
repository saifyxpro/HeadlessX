# HeadlessX production domain setup

# Public domains
HEADLESSX_WEB_DOMAIN=dashboard.example.com
HEADLESSX_API_DOMAIN=api.example.com

# Email for Caddy certificate management
CADDY_EMAIL=ops@example.com

# Upstreams on the Docker network
HEADLESSX_WEB_UPSTREAM=web:3000
HEADLESSX_API_UPSTREAM=api:8000

# Docker network used by the HeadlessX core stack
HEADLESSX_DOCKER_NETWORK=docker_headlessx-network
