# HeadlessX Docker environment

# Compose host ports
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
HTML_TO_MARKDOWN_HOST_PORT=8081
WEB_PORT=3000
PORT=8000

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=headlessx

# API server
HOST=0.0.0.0
NODE_ENV=development

# Required security
DASHBOARD_INTERNAL_API_KEY=replace-with-a-long-random-string
CREDENTIAL_ENCRYPTION_KEY=replace-with-a-different-long-random-string

# Queue and Redis
REDIS_URL=redis://redis:6379

# Search providers
TAVILY_API_KEY=
EXA_API_KEY=

# Local engines
# Full Docker now starts yt-engine inside compose by default.
YT_ENGINE_URL=http://yt-engine:8090
YT_ENGINE_TIMEOUT_MS=45000
YT_ENGINE_PORT=8090
YT_ENGINE_TEMP_DIR=/app/tmp/yt-engine
YT_ENGINE_JOB_TTL_HOURS=12

HTML_TO_MARKDOWN_SERVICE_URL=http://html-to-md:8080
HTML_TO_MARKDOWN_TIMEOUT_MS=60000

# Web dashboard
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://api:8000

# Set this only when the dashboard is hosted on a custom origin.
# FRONTEND_URL=https://dashboard.example.com
