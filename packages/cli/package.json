{
  "name": "@headlessx-cli/core",
  "version": "0.1.23",
  "description": "Bootstrap and operator CLI for HeadlessX local installs, website extraction, search, YouTube, and jobs workflows.",
  "main": "dist/index.js",
  "bin": {
    "headlessx": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "local": "node dist/index.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build",
    "prepare": "node scripts/prepare.mjs",
    "format": "prettier --write \"src/**/*.{ts,json}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\" \"*.{json,md}\"",
    "type-check": "tsc --noEmit",
    "test:watch": "vitest",
    "test": "vitest run",
    "publish-beta": "npm publish --tag beta",
    "publish-prod": "npm publish --access public"
  },
  "lint-staged": {
    "*.{ts,json,md}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "headlessx",
    "cli",
    "web-scraping",
    "crawler",
    "scraper",
    "data-extraction",
    "llm",
    "markdown",
    "search",
    "web search",
    "youtube"
  ],
  "author": "saifyxpro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saifyxpro/HeadlessX.git"
  },
  "bugs": {
    "url": "https://github.com/saifyxpro/HeadlessX/issues"
  },
  "homepage": "https://headlessx.saify.me/docs",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "commander": "^14.0.2",
    "picocolors": "^1.1.1"
  }
}
